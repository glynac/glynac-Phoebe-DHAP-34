# Airflow Configuration
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

# Airflow Web UI
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# External PostgreSQL for Data Pipeline
PG_HOST=postgres-data
PG_PORT=5433
PG_DB=airflow_data
PG_USER=pipeline_user
PG_PASSWORD=pipeline_password

# Additional Python Requirements (if needed)
_PIP_ADDITIONAL_REQUIREMENTS=pandas psycopg2-binary pyyaml
