# ===== MinIO / S3-compatible =====
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_SECURE=false
MINIO_REGION=us-east-1
MINIO_BUCKET=bronze
MINIO_PREFIX=customer_care_emails

# ===== Output formatting =====
OUTPUT_PARTITION_FIELD=ingest_date
OUTPUT_COMPRESSION=snappy

# ===== CSV parsing hints =====
CSV_DELIMITER=,
CSV_HEADER=true
CSV_ENCODING=UTF-8